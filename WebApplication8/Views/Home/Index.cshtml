            <button type="submit" style="padding: 10px; background-color: #6C4F3D; color: white; border: none; border-radius: 6px; cursor: pointer;">
                Save Details
            </button>
            <div id="saveMessage" style="color: green; display: none;">Details saved!</div>
        </form>
    </div>
