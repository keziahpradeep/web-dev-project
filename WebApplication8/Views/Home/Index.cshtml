    <script>
        function toggleMenu() {
            const menu = document.getElementById('sideMenu');
            const isOpen = menu.style.left === '0px';
            menu.style.left = isOpen ? '-250px' : '0';
        }

        function showContent(sectionId) {
            toggleMenu(); // Closes the menu
            const sections = ['customerDetailsSection', 'itemsSection', 'billsSection']; // Updated IDs to match the HTML
            sections.forEach(id => {
                document.getElementById(id).style.display = 'none'; // Hide all sections first
            });
            document.getElementById(sectionId).style.display = 'flex'; // Show the selected section using flex for centering
            // Hide the main container when a menu section is active
            document.getElementById('mainContainer').style.display = 'none';
        }

        function hideContent() {
            const sections = ['customerDetailsSection', 'itemsSection', 'billsSection'];
            sections.forEach(id => {
                document.getElementById(id).style.display = 'none'; // Hide all menu sections
            });
            // Show the main container again
            document.getElementById('mainContainer').style.display = 'flex'; // Assuming main container is flex
        }

        function logout() {
            toggleMenu();
            // Using a more custom confirm message for better styling integration if needed,
            // though the browser's confirm will still work.
            // For a fully custom confirm, you'd use your custom modal.
            if (confirm("Are you sure you want to logout?")) {
                window.location.href = '/Login'; // This goes to your login.cshtml
            }
        }
    </script>

