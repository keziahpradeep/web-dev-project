    <div id="billsSection" class="menu-content-section">
        <button class="back-button" onclick="hideContent()">← Back</button>
        <h2>Bills & Invoices</h2>
    </div>

    <div class="container" id="mainContainer">
        <div class="left-panel">
            <div class="left-scrollable-content">
                <div class="item-list">
